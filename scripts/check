#!/usr/bin/env bash
# scripts/check - Local CI parity check
#
# Mirrors CI validation gates for deterministic local verification.
# Runs: lint, docs:lint, typecheck, test, audit
#
# Usage:
#   ./scripts/check        # Run all checks
#   ./scripts/check fast   # Run lint + typecheck only (faster feedback)

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track overall status
FAILED=0

run_check() {
    local name="$1"
    local cmd="$2"

    echo ""
    echo "▶ Running: $name"
    echo "  Command: $cmd"
    echo ""

    if eval "$cmd"; then
        echo -e "${GREEN}✓ $name passed${NC}"
        return 0
    else
        echo -e "${RED}✗ $name failed${NC}"
        FAILED=1
        return 1
    fi
}

# Check if pnpm is available
if ! command -v pnpm &> /dev/null; then
    echo -e "${RED}Error: pnpm is required but not installed${NC}"
    echo "Install via: npm install -g pnpm"
    exit 1
fi

# Check if we're in the repo root
if [ ! -f "package.json" ]; then
    echo -e "${RED}Error: Must run from repository root${NC}"
    exit 1
fi

echo "=========================================="
echo "Harness Local CI Check"
echo "=========================================="
echo ""
echo "Repository: $(pwd)"
echo "Package manager: $(pnpm --version)"
echo "Node: $(node --version)"
echo ""

# Fast mode: only lint + typecheck
if [ "${1:-}" = "fast" ]; then
    echo -e "${YELLOW}Running in fast mode (lint + typecheck only)${NC}"
    echo ""

    run_check "lint" "pnpm lint"
    run_check "typecheck" "pnpm typecheck"

    echo ""
    echo "=========================================="
    if [ $FAILED -eq 0 ]; then
        echo -e "${GREEN}Fast check passed!${NC}"
        exit 0
    else
        echo -e "${RED}Fast check failed!${NC}"
        exit 1
    fi
fi

# Full check: mirrors CI
run_check "lint" "pnpm lint"
run_check "docs:lint" "pnpm docs:lint"
run_check "typecheck" "pnpm typecheck"
run_check "test" "pnpm test"
run_check "audit" "pnpm audit"

echo ""
echo "=========================================="
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All checks passed!${NC}"
    echo ""
    echo "This repository is ready for commit/PR."
    exit 0
else
    echo -e "${RED}Some checks failed!${NC}"
    echo ""
    echo "Fix the issues above before committing."
    exit 1
fi
