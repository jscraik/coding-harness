# EditorConfig - https://editorconfig.org
# Consistent coding style across editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space

[Makefile]
indent_style = tab
