{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow-artifact-registry.schema.json",
  "title": "Workflow Artifact Registry",
  "description": "Schema for the canonical workflow artifact registry used by coding-harness. Each entry tracks a promoted workflow artifact with ownership, validation status, and lifecycle metadata.",
  "type": "object",
  "required": ["version", "artifacts"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Registry schema version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this registry"
    },
    "artifacts": {
      "type": "array",
      "description": "List of registered workflow artifacts",
      "items": {
        "$ref": "#/definitions/WorkflowArtifactEntry"
      },
      "minItems": 0
    }
  },
  "additionalProperties": false,
  "definitions": {
    "WorkflowArtifactEntry": {
      "type": "object",
      "required": ["id", "path", "owner", "status", "last_validated_at", "deprecation_policy"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the workflow artifact. Kebab-case.",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "path": {
          "type": "string",
          "description": "Repo-relative path to the artifact file"
        },
        "owner": {
          "type": "string",
          "description": "Accountable maintainer or team"
        },
        "status": {
          "type": "string",
          "description": "Current lifecycle status of the artifact",
          "enum": ["active", "deprecated", "draft", "archived"]
        },
        "last_validated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of the last validation pass",
          "format": "date-time"
        },
        "deprecation_policy": {
          "type": "string",
          "description": "When and how the artifact may be deprecated",
          "enum": ["none", "sunset-date", "superseded-by-completion", "on-demand"]
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the artifact's purpose"
        },
        "superseded_by": {
          "type": "string",
          "description": "ID of the artifact that supersedes this one (when status = deprecated)"
        },
        "sunset_date": {
          "type": "string",
          "description": "ISO 8601 date when the artifact will be archived (when deprecation_policy = sunset-date)",
          "format": "date"
        },
        "tags": {
          "type": "array",
          "description": "Optional classification tags",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
