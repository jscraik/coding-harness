{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://jscraik.dev/coding-harness/rule-lifecycle-manifest.schema.json",
	"title": "Rule Lifecycle Manifest",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "rules"],
	"properties": {
		"schemaVersion": {
			"const": "rule-lifecycle-manifest/v1"
		},
		"rules": {
			"type": "array",
			"minItems": 1,
			"contains": {
				"type": "object",
				"required": ["status"],
				"properties": {
					"status": {
						"const": "active"
					}
				}
			},
			"minContains": 1,
			"items": {
				"$ref": "#/$defs/rule"
			}
		}
	},
	"$defs": {
		"rule": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"title",
				"status",
				"owner",
				"scope",
				"evidence",
				"enforcement",
				"enforcementRefs",
				"lastReviewedAt",
				"reviewCadenceDays",
				"removalCondition"
			],
			"properties": {
				"id": {
					"type": "string",
					"pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
				},
				"title": {
					"type": "string",
					"minLength": 1
				},
				"status": {
					"enum": ["active", "deprecated", "superseded"]
				},
				"owner": {
					"type": "string",
					"minLength": 1
				},
				"scope": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"evidence": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"enforcement": {
					"type": "array",
					"minItems": 1,
					"items": {
						"enum": [
							"doc",
							"lint",
							"test",
							"ci",
							"reviewer",
							"human-escalation"
						]
					}
				},
				"enforcementRefs": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"lastReviewedAt": {
					"type": "string",
					"format": "date"
				},
				"reviewCadenceDays": {
					"type": "integer",
					"minimum": 1
				},
				"removalCondition": {
					"type": "string",
					"minLength": 1
				},
				"supersededBy": {
					"type": "string",
					"pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
				},
				"notes": {
					"type": "string"
				}
			}
		}
	}
}
