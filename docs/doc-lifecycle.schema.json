{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://coding-harness.local/schemas/doc-lifecycle.schema.json",
	"title": "Coding Harness Documentation Lifecycle Metadata",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"doc_schema",
		"doc_type",
		"authority",
		"canon_class",
		"distribution",
		"audience",
		"lifecycle_state",
		"owner",
		"created",
		"last_reviewed",
		"review_cadence",
		"maintenance_trigger",
		"semver_impact",
		"validated_by",
		"depends_on"
	],
	"properties": {
		"doc_schema": {
			"const": "coding-harness-doc/v1"
		},
		"doc_type": {
			"enum": [
				"architecture",
				"contributing",
				"control-plane",
				"docs-index",
				"governance",
				"lifecycle",
				"operator-instructions",
				"product",
				"security",
				"skill"
			]
		},
		"authority": {
			"enum": ["canon", "supporting", "generated", "historical"],
			"description": "Authority lane used by readers and agents when deciding whether a document can define current repository behavior."
		},
		"canon_class": {
			"enum": ["canonical", "supporting", "generated", "historical"],
			"description": "Canonicality class for routing and docs-gate reporting; mirrors authority with reader-facing wording for lifecycle inventories.",
			"deprecated": true,
			"x-deprecated-reason": "Use 'authority' field instead; 'canon_class' is maintained for backward compatibility"
		},
		"distribution": {
			"enum": [
				"source-only",
				"downstream-template",
				"packaged-skill",
				"generated",
				"example-only"
			]
		},
		"audience": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string"
			}
		},
		"lifecycle_state": {
			"enum": [
				"proposed",
				"experimental",
				"active",
				"deprecated",
				"superseded",
				"archived"
			]
		},
		"owner": {
			"type": "string",
			"minLength": 1
		},
		"created": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"last_reviewed": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"review_cadence": {
			"type": "string",
			"minLength": 1
		},
		"maintenance_trigger": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string"
			}
		},
		"semver_impact": {
			"enum": ["none", "patch", "minor", "major"]
		},
		"validated_by": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string"
			}
		},
		"depends_on": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"superseded_by": {
			"type": "string"
		},
		"remove_after": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		}
	}
}
