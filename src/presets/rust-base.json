{
	"version": "1.0",
	"riskTierRules": {
		"src/auth*/**": "high",
		"src/api*/**": "high",
		"src/lib*/**": "medium",
		"**/tests/**": "low"
	},
	"mergePolicy": {
		"high": ["review-gate", "evidence-verify"],
		"medium": ["review-gate"],
		"low": []
	},
	"reviewPolicy": {
		"timeoutSeconds": 600,
		"timeoutAction": "fail",
		"requiredChecks": ["lint", "test", "security-scan"],
		"enforceReviewerIndependence": true
	},
	"branchProtection": {
		"requiredChecks": ["lint", "test", "security-scan"]
	},
	"evidencePolicy": {
		"requiredFor": [],
		"allowedTypes": ["png", "jpeg"],
		"maxFileSizeBytes": 1048576
	},
	"diffBudget": {
		"maxFiles": 10,
		"maxNetLOC": 400,
		"overrideLabel": "diff-budget-override"
	},
	"packageManagerPolicy": {
		"allowedManagers": ["cargo"],
		"requiredManager": "cargo"
	}
}
