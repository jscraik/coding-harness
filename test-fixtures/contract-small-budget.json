{
	"version": "1.0",
	"riskTierRules": {
		"src/auth/**": "high",
		"src/api/**": "high",
		"src/lib/**": "medium",
		"**/*.test.ts": "low"
	},
	"reviewPolicy": {
		"timeoutSeconds": 600,
		"timeoutAction": "fail",
		"scoreThresholds": {
			"minOprScore": 4,
			"minGreptileScore": 5,
			"scoreScale": 5
		}
	},
	"diffBudget": {
		"maxFiles": 5,
		"maxNetLOC": 100
	}
}
