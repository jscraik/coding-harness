{
	"name": "@brainwav/coding-harness",
	"version": "0.15.1",
	"files": [
		"dist",
		"scripts/codex-preflight.sh",
		"scripts/codex-preflight-local-memory-legacy.sh",
		"scripts/verify-work.sh",
		"scripts/validate-codestyle.sh",
		"scripts/check-doc-style.sh",
		"scripts/check-related-tests.sh",
		"scripts/refresh-diagram-context.sh",
		"scripts/check-diagram-freshness.sh",
		"scripts/check-public-api-docs.mjs",
		"scripts/check-code-size.mjs",
		"scripts/check-self-affirming-tests.mjs",
		"scripts/lib",
		"scripts/check-codestyle-parity.sh",
		"scripts/check-git-common-config.sh",
		"scripts/check-semgrep-changed.sh",
		"scripts/check-semgrep-full.sh",
		"scripts/semgrep-bootstrap.sh",
		"scripts/semgrep-pre-push.yml",
		"scripts/prepare-worktree.sh",
		"scripts/new-task.sh",
		"scripts/harness-cli.sh",
		"codestyle",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		".agents/skills/coding-harness"
	],
	"type": "module",
	"description": "Control plane for agentic development",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jscraik/coding-harness.git"
	},
	"bugs": {
		"url": "https://linear.app/jscraik/project/coding-harness-bb735dbbda79"
	},
	"publishConfig": {
		"access": "restricted",
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"harness": "dist/cli.js"
	},
	"scripts": {
		"check": "pnpm lint && pnpm docs:lint && pnpm docs:ubiquitous:guard && pnpm docs:steering:guard && pnpm skill:validate && pnpm workflow:validate && pnpm typecheck && pnpm quality:docstrings && pnpm quality:size && pnpm quality:self-affirming && pnpm test:related && pnpm test:ci && pnpm audit",
		"publish:release": "pnpm check && pnpm build && npm publish --access restricted --ignore-scripts=false",
		"lint": "pnpm codestyle:parity && pnpm codex-preflight:check && biome check .",
		"lint:fix": "biome check . --write",
		"fmt": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:ci": "bash scripts/test-ci.sh",
		"test:watch": "vitest",
		"test:deep": "pnpm check && pnpm test:artifacts",
		"test:evals": "node --import tsx scripts/run-harness-evals.mjs",
		"test:harness-upgrade-matrix": "node scripts/test-harness-upgrade-matrix.mjs",
		"test:integration": "pnpm vitest run src/commands/agent-first-throughput.integration.test.ts",
		"test:e2e": "pnpm e2e",
		"build": "rm -rf dist && tsc && cp -r src/presets dist/presets && cp -r src/templates dist/templates && chmod +x dist/cli.js",
		"prepublishOnly": "pnpm check && pnpm build",
		"changelog": "standard-version --skip.bump --skip.tag --skip.commit",
		"release": "standard-version",
		"audit": "bash scripts/run-audit-with-timeout.sh",
		"audit:strict": "pnpm audit --audit-level=high",
		"docs:lint": "pnpm markdownlint",
		"docs:ubiquitous:guard": "bash scripts/check-ubiquitous-language-link.sh",
		"docs:steering:guard": "node scripts/check-steering-feedback-contract.cjs",
		"docs:style:changed": "bash scripts/check-doc-style.sh",
		"skill:validate": "node scripts/validate-packaged-skill.cjs",
		"workflow:normalize": "node scripts/normalize-workflow-contracts.cjs",
		"workflow:validate": "node scripts/validate-workflow-contracts.cjs",
		"observed:eval-usage": "tsx scripts/collect-observed-eval-usage.ts",
		"markdownlint": "markdownlint-cli2 \"**/*.md\"",
		"codestyle:parity": "bash scripts/check-codestyle-parity.sh",
		"codestyle:validate": "bash scripts/validate-codestyle.sh",
		"quality:docstrings": "node scripts/check-public-api-docs.mjs",
		"quality:size": "node scripts/check-code-size.mjs",
		"quality:self-affirming": "node scripts/check-self-affirming-tests.mjs --all",
		"secrets:staged": "bash scripts/check-staged-secrets.sh",
		"semgrep:changed": "bash scripts/check-semgrep-changed.sh",
		"test:artifacts": "bash scripts/test-with-artifacts.sh all",
		"test:artifacts:unit": "bash scripts/test-with-artifacts.sh unit",
		"test:artifacts:integration": "bash scripts/test-with-artifacts.sh integration",
		"test:artifacts:e2e": "bash scripts/test-with-artifacts.sh e2e",
		"test:artifacts:evals": "bash scripts/test-with-artifacts.sh evals",
		"test:related": "bash scripts/check-related-tests.sh",
		"e2e": "tsx e2e/run-e2e.ts",
		"e2e:github": "tsx e2e/run-e2e.ts github-integration",
		"e2e:linear": "tsx e2e/run-e2e.ts linear-integration",
		"e2e:pipeline": "tsx e2e/run-e2e.ts command-pipeline",
		"e2e:ci": "tsx e2e/run-e2e.ts --reporter json --parallel 2",
		"harness:ui:capture-browser-evidence": "node --import tsx src/cli.ts ui:explore --mode execute --interactions --output artifacts/ui-evidence --json",
		"vale": "vale --config .vale.ini AGENTS.md docs",
		"codex-preflight:check": "node scripts/sync-codex-preflight.cjs --check",
		"codex-preflight:sync": "node scripts/sync-codex-preflight.cjs --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@brainwav/diagram": "^1.1.0",
		"@total-typescript/shoehorn": "^0.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/lodash": "^4.17.24",
		"@types/node": "^24.12.2",
		"@types/picomatch": "^4.0.2",
		"@types/semver": "^7.7.1",
		"@vitest/coverage-v8": "^4.1.5",
		"@vvago/vale": "^3.12.0",
		"markdownlint-cli2": "^0.21.0",
		"standard-version": "^9.5.0",
		"tsx": "^4.21.0",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24.0.0"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.3.0",
		"@octokit/core": "^7.0.6",
		"@octokit/plugin-retry": "^8.1.0",
		"@octokit/plugin-throttling": "^11.0.3",
		"@octokit/request-error": "^7.1.0",
		"@octokit/rest": "^22.0.1",
		"better-sqlite3": "^12.6.2",
		"diff": "^8.0.3",
		"lodash": "^4.18.1",
		"picomatch": "^4.0.4",
		"semver": "^7.7.4",
		"sqlite-vec": "0.1.7-alpha.2",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"overrides": {
			"axios": "^1.16.0",
			"@vvago/vale>axios": "^1.16.0",
			"brace-expansion": "^5.0.6",
			"follow-redirects": "^1.16.0",
			"handlebars": "^4.7.9",
			"lodash": "^4.18.1",
			"micromatch>picomatch": "^2.3.2",
			"minimatch": "^10.2.3",
			"picomatch": "^4.0.4",
			"postcss": "^8.5.10",
			"tar": "^7.5.10",
			"yaml": "^2.8.3",
			"vite": ">=7.3.2 <8",
			"handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
			"axios@<1.15.2": ">=1.16.0",
			"brace-expansion@>=4.0.0 <5.0.6": ">=5.0.6",
			"handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
			"picomatch@<2.3.2": ">=2.3.2",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"yaml@>=2.0.0 <2.8.3": ">=2.8.3"
		}
	},
	"license": "Apache-2.0",
	"homepage": "https://github.com/jscraik/coding-harness#readme"
}
