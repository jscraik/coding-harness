{
	"name": "@brainwav/coding-harness",
	"version": "0.11.12",
	"files": [
		"dist",
		"scripts/codex-preflight.sh",
		"scripts/verify-work.sh",
		"scripts/validate-codestyle.sh",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		".agents/skills/coding-harness"
	],
	"type": "module",
	"description": "Control plane for agentic development",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jscraik/coding-harness.git"
	},
	"bugs": {
		"url": "https://linear.app/jscraik/project/coding-harness-bb735dbbda79"
	},
	"publishConfig": {
		"access": "restricted",
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"harness": "dist/cli.js"
	},
	"scripts": {
		"check": "pnpm lint && pnpm docs:lint && pnpm skill:validate && pnpm workflow:validate && pnpm typecheck && pnpm test && pnpm audit",
		"publish:release": "pnpm check && pnpm build && npm publish --access restricted --ignore-scripts=false",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"fmt": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:ci": "bash scripts/test-ci.sh",
		"test:watch": "vitest",
		"test:deep": "pnpm check && pnpm test:artifacts",
		"build": "tsc && cp -r src/presets dist/presets && cp -r src/templates dist/templates && cp CODESTYLE.md dist/templates/CODESTYLE.md && chmod +x dist/cli.js",
		"prepublishOnly": "pnpm check && pnpm build",
		"changelog": "standard-version --skip.bump --skip.tag --skip.commit",
		"release": "standard-version",
		"audit": "bash scripts/run-audit-with-timeout.sh",
		"audit:strict": "pnpm audit --audit-level=high",
		"docs:lint": "pnpm markdownlint",
		"docs:style:changed": "bash scripts/check-doc-style.sh",
		"skill:validate": "node scripts/validate-packaged-skill.cjs",
		"workflow:normalize": "node scripts/normalize-workflow-contracts.cjs",
		"workflow:validate": "node scripts/validate-workflow-contracts.cjs",
		"markdownlint": "markdownlint-cli2 \"**/*.md\"",
		"codestyle:validate": "bash scripts/validate-codestyle.sh",
		"secrets:staged": "bash scripts/check-staged-secrets.sh",
		"semgrep:changed": "bash scripts/check-semgrep-changed.sh",
		"test:artifacts": "bash scripts/test-with-artifacts.sh all",
		"test:artifacts:unit": "bash scripts/test-with-artifacts.sh unit",
		"test:artifacts:integration": "bash scripts/test-with-artifacts.sh integration",
		"test:artifacts:e2e": "bash scripts/test-with-artifacts.sh e2e",
		"test:related": "bash scripts/check-related-tests.sh",
		"e2e": "tsx e2e/run-e2e.ts",
		"e2e:github": "tsx e2e/run-e2e.ts github-integration",
		"e2e:linear": "tsx e2e/run-e2e.ts linear-integration",
		"e2e:pipeline": "tsx e2e/run-e2e.ts command-pipeline",
		"e2e:ci": "tsx e2e/run-e2e.ts --reporter json --parallel 2",
		"harness:ui:capture-browser-evidence": "pnpm exec tsx src/cli.ts ui:explore --mode execute --interactions --output artifacts/ui-evidence --json",
		"postinstall": "command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true",
		"vale": "vale --config .vale.ini AGENTS.md CLAUDE.md docs"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@brainwav/diagram": "^1.0.8",
		"@types/better-sqlite3": "^7.6.13",
		"@types/lodash": "^4.17.24",
		"@types/node": "^22.19.11",
		"@types/picomatch": "^4.0.2",
		"@types/semver": "^7.7.1",
		"@vitest/coverage-v8": "^3.2.4",
		"@vvago/vale": "^3.12.0",
		"markdownlint-cli2": "^0.21.0",
		"simple-git-hooks": "^2.13.1",
		"standard-version": "^9.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=24.0.0"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.3.0",
		"@octokit/plugin-retry": "^7.2.1",
		"@octokit/plugin-throttling": "^9.6.1",
		"@octokit/request-error": "^7.1.0",
		"@octokit/rest": "^21.1.1",
		"better-sqlite3": "^12.6.2",
		"diff": "^8.0.3",
		"lodash": "^4.18.1",
		"picomatch": "^4.0.4",
		"semver": "^7.7.4",
		"sqlite-vec": "0.1.7-alpha.2"
	},
	"pnpm": {
		"overrides": {
			"brace-expansion": "^5.0.5",
			"handlebars": "^4.7.9",
			"lodash": "^4.18.1",
			"micromatch>picomatch": "^2.3.2",
			"minimatch": "^10.2.3",
			"picomatch": "^4.0.4",
			"tar": "^7.5.10",
			"yaml": "^2.8.3",
			"handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
			"brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
			"handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
			"picomatch@<2.3.2": ">=2.3.2",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"yaml@>=2.0.0 <2.8.3": ">=2.8.3"
		}
	},
	"simple-git-hooks": {
		"pre-commit": "make hooks-pre-commit",
		"commit-msg": "node scripts/validate-commit-msg.js $1",
		"pre-push": "make hooks-pre-push"
	},
	"license": "Apache-2.0",
	"homepage": "https://github.com/jscraik/coding-harness#readme"
}
