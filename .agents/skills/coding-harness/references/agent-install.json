{
	"schema_version": "1.0",
	"package": "@brainwav/coding-harness",
	"registry_auth": "NPM_TOKEN",
	"ci_provider": "circleci",
	"install_command": "mise install -g npm:@brainwav/coding-harness",
	"init_command": "harness init",
	"verify_command": "harness check-environment --json",
	"phases": [
		{
			"id": "preflight",
			"steps": [
				"node --version",
				"pnpm --version",
				"mise --version",
				"test -n \"${NPM_TOKEN:-}\""
			]
		},
		{
			"id": "auth",
			"steps": [
				"npm whoami",
				"npm view @brainwav/coding-harness dist-tags --json"
			]
		},
		{
			"id": "install",
			"steps": [
				"mise install -g npm:@brainwav/coding-harness",
				"harness --version",
				"harness --help"
			]
		},
		{
			"id": "init",
			"steps": [
				"harness init --dry-run",
				"harness init",
				"harness init --check-updates"
			]
		},
		{
			"id": "validate",
			"steps": [
				"bash scripts/codex-preflight.sh --stack auto --mode required",
				"harness check-environment --json",
				"harness verify-coderabbit",
				"harness check-authz --contract harness.contract.json --repo <owner/repo> --branch main",
				"pnpm check"
			]
		}
	],
	"migration_commands": {
		"preview": "harness ci-migrate prepare --provider circleci --dry-run",
		"apply": "harness ci-migrate prepare --provider circleci --apply",
		"verify": "harness ci-migrate verify --snapshot <snapshot-id>",
		"commit": "harness ci-migrate commit --snapshot <snapshot-id>",
		"abort": "harness ci-migrate abort --snapshot <snapshot-id>"
	},
	"scaffolded_files": {
		"enforced": [
			"harness.contract.json",
			".harness/ci-required-checks.json",
			"memory.json",
			".circleci/config.yml",
			".coderabbit.yaml",
			"scripts/check-environment.sh"
		],
		"adaptable": [
			".github/PULL_REQUEST_TEMPLATE.md",
			".github/CODEOWNERS",
			"CONTRIBUTING.md",
			"Makefile",
			"biome.json",
			"prek.toml",
			".mise.toml",
			"scripts/codex-preflight.sh"
		],
		"agent_environment": [".codex/environments/environment.toml"]
	},
	"capability_boundaries": {
		"can": [
			"Scaffold governance files",
			"Verify local policy and environment state",
			"Run auth-bound remote checks when credentials are provided",
			"Generate Codex environment action blocks from package.json scripts"
		],
		"cannot": [
			"Create or rotate secrets",
			"Install third-party GitHub Apps",
			"Bypass branch protection",
			"Overwrite user-customized environment.toml without approval"
		]
	}
}
