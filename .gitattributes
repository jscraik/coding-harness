# Auto detect text files and normalize to LF
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Configuration
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Generated files - don't diff
pnpm-lock.yaml -diff
*.snap -diff

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# Linguist overrides (reduce perceived repo language size)
scripts/*.js linguist-generated=true
AI/diagrams/*.mmd linguist-documentation=true
