{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/coding-harness/contracts/artifact-runtime-surface.schema.json",
	"title": "ArtifactRuntimeSurface/v1",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"surfaceId",
		"generatedAt",
		"producer",
		"runtimeStatus",
		"evidenceUse",
		"surfaceKind",
		"headSha",
		"currentHeadSha",
		"artifact",
		"lineage",
		"preview",
		"claimSupport",
		"freshness",
		"blockers",
		"nextAction"
	],
	"properties": {
		"schemaVersion": { "const": "artifact-runtime-surface/v1" },
		"surfaceId": { "$ref": "#/$defs/pointer" },
		"generatedAt": { "type": "string", "format": "date-time" },
		"producer": { "$ref": "#/$defs/pointer" },
		"runtimeStatus": { "const": "not_yet_emitted" },
		"evidenceUse": {
			"type": "string",
			"enum": ["orientation", "audit_trail", "claim_support"]
		},
		"surfaceKind": {
			"type": "string",
			"enum": [
				"implementation_notes",
				"review_artifact",
				"screenshot",
				"csv",
				"pdf",
				"document",
				"runtime_card",
				"report",
				"lifecycle_artifact",
				"other"
			]
		},
		"headSha": { "$ref": "#/$defs/headSha" },
		"currentHeadSha": { "$ref": "#/$defs/headSha" },
		"artifact": { "$ref": "#/$defs/artifact" },
		"lineage": { "$ref": "#/$defs/lineage" },
		"preview": { "$ref": "#/$defs/preview" },
		"claimSupport": { "$ref": "#/$defs/claimSupport" },
		"freshness": { "$ref": "#/$defs/freshness" },
		"blockers": {
			"type": "array",
			"items": { "$ref": "#/$defs/blocker" }
		},
		"nextAction": { "$ref": "#/$defs/pointer" }
	},
	"$defs": {
		"pointer": {
			"type": "string",
			"minLength": 2,
			"maxLength": 256,
			"pattern": "^[A-Za-z0-9][A-Za-z0-9:._/@#?=&+,-]{1,255}$"
		},
		"repoPath": {
			"type": "string",
			"minLength": 1,
			"maxLength": 256,
			"pattern": "^(?:[A-Za-z0-9._@+-]+/)*[A-Za-z0-9._@+-]+$"
		},
		"headSha": {
			"anyOf": [
				{ "type": "string", "pattern": "^[0-9a-f]{40}$" },
				{ "type": "null" }
			]
		},
		"freshness": {
			"type": "string",
			"enum": ["current", "stale", "missing", "unknown", "not_applicable"]
		},
		"artifact": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"path",
				"exists",
				"sizeBytes",
				"sha256",
				"mediaType",
				"frontMatterStatus",
				"producedAt"
			],
			"properties": {
				"path": { "$ref": "#/$defs/repoPath" },
				"exists": { "type": "boolean" },
				"sizeBytes": { "type": "integer", "minimum": 0 },
				"sha256": {
					"anyOf": [
						{ "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
						{ "type": "null" }
					]
				},
				"mediaType": {
					"type": "string",
					"pattern": "^[a-z0-9][a-z0-9.+-]*/[a-z0-9][a-z0-9.+-]*$"
				},
				"frontMatterStatus": {
					"type": "string",
					"enum": ["current", "stale", "missing", "not_applicable"]
				},
				"producedAt": { "type": "string", "format": "date-time" }
			}
		},
		"lineage": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"producer",
				"sourceRefs",
				"runtimeIdentityRefs",
				"verifierRefs",
				"headSha"
			],
			"properties": {
				"producer": { "$ref": "#/$defs/pointer" },
				"sourceRefs": {
					"type": "array",
					"minItems": 1,
					"items": { "$ref": "#/$defs/pointer" }
				},
				"runtimeIdentityRefs": {
					"type": "array",
					"minItems": 1,
					"items": { "$ref": "#/$defs/pointer" }
				},
				"verifierRefs": {
					"type": "array",
					"minItems": 1,
					"items": { "$ref": "#/$defs/verifierRef" }
				},
				"headSha": { "$ref": "#/$defs/headSha" }
			}
		},
		"verifierRef": {
			"type": "object",
			"additionalProperties": false,
			"required": ["ref", "verifiedAt"],
			"properties": {
				"ref": { "$ref": "#/$defs/pointer" },
				"verifiedAt": { "type": "string", "format": "date-time" }
			}
		},
		"preview": {
			"type": "object",
			"additionalProperties": false,
			"required": ["status", "ref", "checkedAt"],
			"properties": {
				"status": {
					"type": "string",
					"enum": ["current", "missing", "broken", "not_applicable"]
				},
				"ref": {
					"anyOf": [
						{
							"type": "string",
							"pattern": "^preview:(?:browser/[A-Za-z0-9._:@#?=&+,-]{2,200}|artifact/[A-Za-z0-9._:@#?=&+,-]{2,200}|file/(?:[A-Za-z0-9._@+-]+/)*[A-Za-z0-9._@+-]+|not-applicable)$"
						},
						{ "type": "null" }
					]
				},
				"checkedAt": {
					"anyOf": [
						{ "type": "string", "format": "date-time" },
						{ "type": "null" }
					]
				}
			}
		},
		"claimSupport": {
			"type": "object",
			"additionalProperties": false,
			"required": ["status", "supportedClaimRefs", "reason"],
			"properties": {
				"status": {
					"type": "string",
					"enum": ["supported", "unsupported", "blocked"]
				},
				"supportedClaimRefs": {
					"type": "array",
					"items": {
						"type": "string",
						"pattern": "^claim:(?:delivery-truth|review-state|runtime-card|root-hygiene|external-state|judge-pm)/[A-Za-z0-9._:@#?=&+,-]{2,200}$"
					}
				},
				"reason": { "$ref": "#/$defs/pointer" }
			}
		},
		"blocker": {
			"type": "object",
			"additionalProperties": false,
			"required": ["class", "reason", "nextAction"],
			"properties": {
				"class": {
					"type": "string",
					"enum": [
						"missing_path",
						"zero_size",
						"missing_checksum",
						"stale_front_matter",
						"broken_preview",
						"unsupported_claim",
						"mismatched_lineage",
						"stale_surface",
						"unsafe_reference"
					]
				},
				"reason": { "$ref": "#/$defs/pointer" },
				"nextAction": { "$ref": "#/$defs/pointer" }
			}
		}
	}
}
