{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/schemas/cli-json-contracts-manifest.schema.json",
	"title": "CLI JSON Contracts Manifest",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "generatedAt", "contracts"],
	"properties": {
		"schemaVersion": {
			"const": "cli-json-contracts-manifest/v1"
		},
		"generatedAt": {
			"type": "string",
			"format": "date-time"
		},
		"contracts": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"name",
					"command",
					"expectedSchemaVersion",
					"schemaPath",
					"examplePath",
					"liveValidation"
				],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					},
					"command": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"expectedSchemaVersion": {
						"enum": ["harness-command-catalog/v3", "harness-decision/v1"]
					},
					"schemaPath": {
						"type": "string",
						"minLength": 1
					},
					"examplePath": {
						"type": "string",
						"minLength": 1
					},
					"liveValidation": {
						"type": "object",
						"additionalProperties": false,
						"required": ["enabled", "allowedExitCodes", "stdoutJson"],
						"properties": {
							"enabled": {
								"type": "boolean"
							},
							"allowedExitCodes": {
								"type": "array",
								"minItems": 1,
								"uniqueItems": true,
								"items": {
									"type": "integer",
									"minimum": 0
								}
							},
							"stdoutJson": {
								"type": "boolean"
							},
							"reason": {
								"type": "string",
								"minLength": 1
							}
						}
					}
				}
			}
		}
	}
}
