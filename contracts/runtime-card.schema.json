{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/schemas/runtime-card.schema.json",
	"title": "Runtime Card",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"schemaVersion",
		"generatedAt",
		"issueKey",
		"lifecycle",
		"summary",
		"nextSafeAction",
		"branch",
		"pullRequest",
		"artifacts",
		"linear",
		"phaseExit",
		"sources",
		"blockers",
		"attemptLedger",
		"recoveryEvent"
	],
	"properties": {
		"schemaVersion": {
			"const": "runtime-card/v1"
		},
		"generatedAt": {
			"type": "string",
			"format": "date-time"
		},
		"issueKey": {
			"type": ["string", "null"]
		},
		"lifecycle": {
			"enum": [
				"planned",
				"active",
				"implemented",
				"locally_validated",
				"review_pending",
				"ci_blocked",
				"merge_ready",
				"merged",
				"closeout_pending",
				"reconciled",
				"closed",
				"stale",
				"superseded",
				"blocked",
				"unknown"
			]
		},
		"summary": {
			"type": "string"
		},
		"nextSafeAction": {
			"type": "string"
		},
		"branch": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "clean", "ref"],
			"properties": {
				"name": {
					"type": ["string", "null"]
				},
				"clean": {
					"type": ["boolean", "null"]
				},
				"ref": {
					"type": ["string", "null"]
				}
			}
		},
		"pullRequest": {
			"type": "object",
			"additionalProperties": false,
			"required": ["number", "state", "isDraft", "mergeStateStatus", "url"],
			"properties": {
				"number": {
					"type": ["integer", "null"],
					"minimum": 0
				},
				"state": {
					"type": ["string", "null"]
				},
				"isDraft": {
					"type": ["boolean", "null"]
				},
				"mergeStateStatus": {
					"type": ["string", "null"]
				},
				"url": {
					"type": ["string", "null"]
				}
			}
		},
		"artifacts": {
			"type": "object",
			"additionalProperties": false,
			"required": ["activeSpec", "activePlan", "status", "staleRefs"],
			"properties": {
				"activeSpec": {
					"type": ["string", "null"]
				},
				"activePlan": {
					"type": ["string", "null"]
				},
				"status": {
					"enum": ["current", "stale", "missing", "superseded", "unknown"]
				},
				"staleRefs": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"linear": {
			"type": "object",
			"additionalProperties": false,
			"required": ["issueKey", "freshness", "actionRequired"],
			"properties": {
				"issueKey": {
					"type": ["string", "null"]
				},
				"freshness": {
					"enum": ["current", "stale", "missing", "unknown"]
				},
				"status": {
					"type": ["string", "null"]
				},
				"statusType": {
					"type": ["string", "null"]
				},
				"url": {
					"type": ["string", "null"]
				},
				"actionRequired": {
					"type": ["string", "null"]
				}
			}
		},
		"phaseExit": {
			"type": "object",
			"additionalProperties": false,
			"required": ["status", "reason"],
			"properties": {
				"status": {
					"enum": ["pass", "fail", "blocked", "not_run", "unknown"]
				},
				"reason": {
					"type": ["string", "null"]
				}
			}
		},
		"sources": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["kind", "ref", "freshness", "status", "failureClass"],
				"properties": {
					"kind": {
						"enum": [
							"git",
							"pr",
							"linear",
							"artifact",
							"validation",
							"review",
							"session",
							"phase_exit"
						]
					},
					"ref": {
						"type": "string",
						"minLength": 1
					},
					"freshness": {
						"enum": ["current", "stale", "missing", "unknown"]
					},
					"status": {
						"enum": ["usable", "empty", "invalid", "blocked"]
					},
					"failureClass": {
						"type": ["string", "null"]
					}
				}
			}
		},
		"codexRuntime": {
			"type": "object",
			"additionalProperties": true,
			"description": "Compact Codex runtime projection. This nested object intentionally remains extensible because it is validated by the TypeScript codex-runtime projection validator."
		},
		"blockers": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"attemptLedger": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schemaVersion",
				"command",
				"attempt",
				"maxAttempts",
				"firstFailure",
				"retryDecision",
				"owner",
				"stopReason",
				"nextAction",
				"evidenceRefs"
			],
			"properties": {
				"schemaVersion": {
					"const": "attempt-ledger/v1"
				},
				"command": {
					"const": "runtime-card"
				},
				"attempt": {
					"type": "integer",
					"minimum": 1
				},
				"maxAttempts": {
					"type": "integer",
					"minimum": 1
				},
				"firstFailure": {
					"type": ["object", "null"],
					"additionalProperties": true
				},
				"retryDecision": {
					"enum": ["none", "wait", "stop"]
				},
				"owner": {
					"enum": ["codex", "external_service", "operator"]
				},
				"stopReason": {
					"type": ["string", "null"]
				},
				"nextAction": {
					"type": "string"
				},
				"evidenceRefs": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"recoveryEvent": {
			"type": ["object", "null"]
		}
	}
}
