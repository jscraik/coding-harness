{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/schemas/command-catalog.schema.json",
	"title": "Harness Command Catalog",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "generatedAt", "commandCount", "commands"],
	"properties": {
		"schemaVersion": {
			"const": "harness-command-catalog/v4"
		},
		"generatedAt": {
			"type": "string",
			"format": "date-time"
		},
		"commandCount": {
			"type": "integer",
			"minimum": 0
		},
		"commands": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"name",
					"aliases",
					"summary",
					"category",
					"mutability",
					"requiredFlags",
					"expectedArtifacts",
					"effectCharacterization",
					"invocationEffects",
					"retryability",
					"safeFirstAlternatives",
					"tier",
					"primaryAudience",
					"orchestratedBy",
					"agentMode",
					"visibility",
					"execution"
				],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					},
					"aliases": {
						"type": "array",
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"summary": {
						"type": "string",
						"minLength": 1
					},
					"example": {
						"type": "string",
						"minLength": 1
					},
					"category": {
						"enum": [
							"discovery",
							"bootstrap-governance",
							"review-policy",
							"workflow-linear",
							"pilot-remediation",
							"drift-search-evidence",
							"uncategorized"
						]
					},
					"mutability": {
						"enum": ["read", "write"]
					},
					"requiredFlags": {
						"type": "array",
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"expectedArtifacts": {
						"type": "array",
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"effectCharacterization": {
						"enum": ["characterized", "legacy_uncharacterized"]
					},
					"invocationEffects": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": [
								"invocation",
								"effectClasses",
								"targets",
								"providerClass",
								"authority",
								"retryPolicy",
								"rollback",
								"expectedEvidence"
							],
							"properties": {
								"invocation": {
									"type": "string",
									"minLength": 1,
									"pattern": "\\S"
								},
								"effectClasses": {
									"type": "array",
									"minItems": 1,
									"uniqueItems": true,
									"items": {
										"enum": [
											"pure_read",
											"writes_artifact",
											"writes_repository",
											"mutates_git",
											"mutates_external"
										]
									}
								},
								"targets": {
									"type": "array",
									"minItems": 1,
									"items": {
										"type": "string",
										"minLength": 1,
										"pattern": "\\S"
									}
								},
								"providerClass": {
									"type": "string",
									"minLength": 1,
									"pattern": "\\S"
								},
								"authority": {
									"type": "string",
									"minLength": 1,
									"pattern": "\\S"
								},
								"retryPolicy": {
									"enum": ["safe", "conditional", "manual"]
								},
								"rollback": {
									"type": "string",
									"minLength": 1,
									"pattern": "\\S"
								},
								"expectedEvidence": {
									"type": "array",
									"minItems": 1,
									"items": {
										"type": "string",
										"minLength": 1,
										"pattern": "\\S"
									}
								}
							},
							"allOf": [
								{
									"not": {
										"properties": {
											"effectClasses": {
												"allOf": [
													{ "contains": { "const": "pure_read" } },
													{
														"contains": {
															"enum": [
																"writes_artifact",
																"writes_repository",
																"mutates_git",
																"mutates_external"
															]
														}
													}
												]
											}
										}
									}
								}
							]
						}
					},
					"retryability": {
						"enum": ["safe", "conditional", "manual"]
					},
					"safeFirstAlternatives": {
						"type": "array",
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"tier": {
						"enum": ["cockpit", "domain", "plumbing", "legacy"]
					},
					"primaryAudience": {
						"enum": ["agent", "human", "both"]
					},
					"orchestratedBy": {
						"type": "array",
						"items": {
							"enum": ["next", "pr-ready", "fix-review", "learn"]
						}
					},
					"agentMode": {
						"enum": [
							"orient",
							"plan",
							"verify",
							"review",
							"repair",
							"handoff",
							"learn",
							"admin"
						]
					},
					"visibility": {
						"enum": [
							"default",
							"agent",
							"advanced",
							"plumbing",
							"hidden",
							"legacy"
						]
					},
					"execution": {
						"type": "object",
						"additionalProperties": false,
						"required": [
							"resourceLanes",
							"parallelSafe",
							"conflictsWith",
							"timeoutSeconds",
							"cancellable"
						],
						"properties": {
							"resourceLanes": {
								"type": "array",
								"minItems": 1,
								"uniqueItems": true,
								"items": {
									"enum": [
										"repo-read",
										"repo-write",
										"validation",
										"style",
										"artifacts",
										"runtime",
										"git",
										"external"
									]
								}
							},
							"parallelSafe": { "type": "boolean" },
							"conflictsWith": {
								"type": "array",
								"uniqueItems": true,
								"items": {
									"enum": [
										"repo-read",
										"repo-write",
										"validation",
										"style",
										"artifacts",
										"runtime",
										"git",
										"external"
									]
								}
							},
							"timeoutSeconds": {
								"type": "integer",
								"minimum": 1
							},
							"cancellable": { "type": "boolean" }
						}
					}
				}
			}
		}
	}
}
