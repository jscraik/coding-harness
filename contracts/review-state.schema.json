{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/schemas/review-state.schema.json",
	"title": "Review State",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"schemaVersion",
		"generatedAt",
		"pr",
		"fetchReceiptRef",
		"fetchedArtifactHash",
		"verifierIdentity",
		"fetchReceipt",
		"githubReviews",
		"codeRabbit",
		"unresolvedThreads",
		"reviewerArtifacts"
	],
	"properties": {
		"schemaVersion": {
			"const": "review-state/v1"
		},
		"generatedAt": {
			"type": "string",
			"format": "date-time"
		},
		"pr": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"number",
				"repository",
				"url",
				"baseRef",
				"headRef",
				"headSha"
			],
			"properties": {
				"number": {
					"type": "integer",
					"minimum": 1
				},
				"repository": {
					"type": "string",
					"minLength": 1
				},
				"url": {
					"type": "string",
					"format": "uri"
				},
				"baseRef": {
					"type": "string",
					"minLength": 1
				},
				"headRef": {
					"type": "string",
					"minLength": 1
				},
				"headSha": {
					"type": "string",
					"pattern": "^[0-9a-fA-F]{40}$"
				}
			}
		},
		"fetchReceiptRef": {
			"type": "string",
			"minLength": 1
		},
		"fetchedArtifactHash": {
			"type": "string",
			"pattern": "^[a-f0-9]{64}$"
		},
		"verifierIdentity": {
			"type": "string",
			"minLength": 1
		},
		"fetchReceipt": {
			"$ref": "evidence-receipt.schema.json"
		},
		"githubReviews": {
			"type": "object",
			"additionalProperties": false,
			"required": ["decision", "status", "reviewCount"],
			"properties": {
				"decision": {
					"enum": [
						"approved",
						"changes_requested",
						"review_required",
						"unknown",
						"not_applicable"
					]
				},
				"status": {
					"enum": ["pass", "fail", "blocked", "unknown", "not_applicable"]
				},
				"reviewCount": {
					"type": "integer",
					"minimum": 0
				}
			}
		},
		"codeRabbit": {
			"type": "object",
			"additionalProperties": false,
			"required": ["status", "evidenceStatus", "commentCount"],
			"properties": {
				"status": {
					"enum": [
						"completed",
						"skipped_draft",
						"unavailable",
						"failed",
						"unknown",
						"not_applicable"
					]
				},
				"evidenceStatus": {
					"enum": ["pass", "fail", "blocked", "unknown", "not_applicable"]
				},
				"commentCount": {
					"type": "integer",
					"minimum": 0
				}
			}
		},
		"unresolvedThreads": {
			"type": "object",
			"additionalProperties": false,
			"required": ["total", "needsHuman", "autofixable"],
			"properties": {
				"total": {
					"type": "integer",
					"minimum": 0
				},
				"needsHuman": {
					"type": "integer",
					"minimum": 0
				},
				"autofixable": {
					"type": "integer",
					"minimum": 0
				}
			}
		},
		"reviewerArtifacts": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"role",
					"path",
					"expectedProducer",
					"ownershipClassification",
					"receipt"
				],
				"properties": {
					"role": {
						"type": "string",
						"minLength": 1
					},
					"path": {
						"type": "string",
						"minLength": 1
					},
					"expectedProducer": {
						"type": "string",
						"minLength": 1
					},
					"ownershipClassification": {
						"enum": [
							"introduced_by_current_patch",
							"pre_existing",
							"unrelated_dirty_worktree",
							"environment_or_tooling_failure"
						]
					},
					"receipt": {
						"type": "object",
						"additionalProperties": true,
						"required": [
							"schemaVersion",
							"kind",
							"ref",
							"producer",
							"status",
							"freshness",
							"evidenceUse",
							"blockerClass",
							"headSha",
							"sizeBytes"
						],
						"properties": {
							"schemaVersion": {
								"const": "evidence-receipt/v1"
							},
							"kind": {
								"const": "review_artifact"
							},
							"ref": {
								"type": "string",
								"minLength": 1
							},
							"producer": {
								"type": "string",
								"minLength": 1
							},
							"status": {
								"const": "pass"
							},
							"freshness": {
								"const": "current"
							},
							"evidenceUse": {
								"const": "claim_support"
							},
							"blockerClass": {
								"type": ["string", "null"]
							},
							"headSha": {
								"type": "string",
								"minLength": 1
							},
							"sizeBytes": {
								"type": "integer",
								"minimum": 1
							}
						}
					}
				}
			}
		}
	}
}
