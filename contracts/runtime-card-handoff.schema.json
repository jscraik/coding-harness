{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://coding-harness.local/contracts/runtime-card-handoff.schema.json",
	"title": "runtime-card-handoff/v1",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"generatedAt",
		"expiresAt",
		"issueKey",
		"headSha",
		"evidenceUse",
		"freshness",
		"runtimeIdentity",
		"runtimeCard",
		"evidenceBundle",
		"sourceRefs",
		"provenanceRefs",
		"blockers"
	],
	"properties": {
		"schemaVersion": {
			"const": "runtime-card-handoff/v1"
		},
		"generatedAt": {
			"type": "string",
			"format": "date-time"
		},
		"expiresAt": {
			"type": "string",
			"format": "date-time"
		},
		"issueKey": {
			"type": ["string", "null"],
			"minLength": 1
		},
		"headSha": {
			"type": ["string", "null"],
			"minLength": 1
		},
		"evidenceUse": {
			"enum": ["orientation", "audit_trail"]
		},
		"freshness": {
			"enum": ["current", "stale", "missing", "unknown"]
		},
		"runtimeIdentity": {
			"$ref": "#/$defs/runtimeIdentity"
		},
		"runtimeCard": {
			"$ref": "#/$defs/runtimeCardArtifactRef"
		},
		"evidenceBundle": {
			"$ref": "#/$defs/evidenceBundleArtifactRef"
		},
		"sourceRefs": {
			"$ref": "#/$defs/nonEmptyStringArray"
		},
		"provenanceRefs": {
			"$ref": "#/$defs/nonEmptyStringArray"
		},
		"blockers": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		}
	},
	"$defs": {
		"runtimeIdentity": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"issueKey",
				"headSha",
				"generatedAt",
				"provenanceRef",
				"sourceRefs"
			],
			"properties": {
				"issueKey": {
					"type": ["string", "null"],
					"minLength": 1
				},
				"headSha": {
					"type": ["string", "null"],
					"minLength": 1
				},
				"generatedAt": {
					"type": "string",
					"format": "date-time"
				},
				"provenanceRef": {
					"type": "string",
					"minLength": 1
				},
				"sourceRefs": {
					"$ref": "#/$defs/nonEmptyStringArray"
				}
			}
		},
		"runtimeCardArtifactRef": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"path",
				"schemaVersion",
				"sizeBytes",
				"sha256",
				"generatedAt",
				"headSha",
				"sourceRefs",
				"provenanceRefs"
			],
			"properties": {
				"path": {
					"type": "string",
					"minLength": 1,
					"pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).*\\S.*$"
				},
				"schemaVersion": {
					"const": "runtime-card/v1"
				},
				"sizeBytes": {
					"type": "integer",
					"minimum": 1
				},
				"sha256": {
					"type": "string",
					"pattern": "^sha256:[a-f0-9]{64}$"
				},
				"generatedAt": {
					"type": "string",
					"format": "date-time"
				},
				"headSha": {
					"type": ["string", "null"],
					"minLength": 1
				},
				"sourceRefs": {
					"$ref": "#/$defs/nonEmptyStringArray"
				},
				"provenanceRefs": {
					"$ref": "#/$defs/nonEmptyStringArray"
				}
			}
		},
		"evidenceBundleArtifactRef": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"path",
				"schemaVersion",
				"sizeBytes",
				"sha256",
				"generatedAt",
				"headSha",
				"sourceRefs",
				"provenanceRefs"
			],
			"properties": {
				"path": {
					"type": "string",
					"minLength": 1,
					"pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).*\\S.*$"
				},
				"schemaVersion": {
					"const": "runtime-evidence-bundle/v1"
				},
				"sizeBytes": {
					"type": "integer",
					"minimum": 1
				},
				"sha256": {
					"type": "string",
					"pattern": "^sha256:[a-f0-9]{64}$"
				},
				"generatedAt": {
					"type": "string",
					"format": "date-time"
				},
				"headSha": {
					"type": ["string", "null"],
					"minLength": 1
				},
				"sourceRefs": {
					"$ref": "#/$defs/nonEmptyStringArray"
				},
				"provenanceRefs": {
					"$ref": "#/$defs/nonEmptyStringArray"
				}
			}
		},
		"nonEmptyStringArray": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			}
		}
	}
}
