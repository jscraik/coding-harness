{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/schemas/synaipse-improvement-case.schema.json",
	"title": "SynAIpse Improvement Case",
	"description": "An evidence-bound improvement decision with sibling scope, candidate mechanisms, canary, measurement, disposition, and retirement.",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"runtimeStatus",
		"repository",
		"observedAt",
		"observation",
		"classification",
		"siblingInventory",
		"candidates",
		"selectedMechanism",
		"canary",
		"measurement",
		"disposition",
		"owner",
		"retirementCondition"
	],
	"properties": {
		"schemaVersion": { "const": "synaipse-improvement-case/v1" },
		"runtimeStatus": { "const": "not_yet_emitted" },
		"repository": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "sha"],
			"properties": {
				"name": { "$ref": "#/$defs/nonEmptyString" },
				"sha": { "$ref": "#/$defs/sha" }
			}
		},
		"observedAt": { "type": "string", "format": "date-time" },
		"observation": { "$ref": "#/$defs/nonEmptyString" },
		"classification": { "enum": ["local", "systemic"] },
		"siblingInventory": {
			"type": "object",
			"additionalProperties": false,
			"required": ["searched", "changed", "left", "deferred"],
			"properties": {
				"searched": { "$ref": "#/$defs/nonEmptyStringArray" },
				"changed": { "$ref": "#/$defs/stringArray" },
				"left": { "$ref": "#/$defs/stringArray" },
				"deferred": { "$ref": "#/$defs/stringArray" }
			}
		},
		"candidates": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/$defs/candidate" }
		},
		"selectedMechanism": { "$ref": "#/$defs/mechanism" },
		"canary": {
			"type": "object",
			"additionalProperties": false,
			"required": ["command", "expected"],
			"properties": {
				"command": { "$ref": "#/$defs/nonEmptyString" },
				"expected": { "$ref": "#/$defs/nonEmptyString" }
			}
		},
		"measurement": {
			"type": "object",
			"additionalProperties": false,
			"required": ["metric", "target"],
			"properties": {
				"metric": { "$ref": "#/$defs/nonEmptyString" },
				"target": { "$ref": "#/$defs/nonEmptyString" }
			}
		},
		"disposition": { "$ref": "#/$defs/disposition" },
		"owner": { "$ref": "#/$defs/nonEmptyString" },
		"retirementCondition": { "$ref": "#/$defs/nonEmptyString" }
	},
	"$defs": {
		"nonEmptyString": {
			"type": "string",
			"minLength": 1
		},
		"stringArray": {
			"type": "array",
			"items": { "$ref": "#/$defs/nonEmptyString" }
		},
		"nonEmptyStringArray": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/$defs/nonEmptyString" }
		},
		"sha": {
			"type": "string",
			"minLength": 40,
			"maxLength": 40
		},
		"disposition": {
			"enum": ["change", "retain", "delete", "defer"]
		},
		"candidate": {
			"type": "object",
			"additionalProperties": false,
			"required": ["disposition", "rationale", "rollback"],
			"properties": {
				"disposition": { "$ref": "#/$defs/disposition" },
				"rationale": { "$ref": "#/$defs/nonEmptyString" },
				"rollback": { "$ref": "#/$defs/nonEmptyString" }
			}
		},
		"mechanism": {
			"type": "object",
			"additionalProperties": false,
			"required": ["disposition", "rationale"],
			"properties": {
				"disposition": { "$ref": "#/$defs/disposition" },
				"rationale": { "$ref": "#/$defs/nonEmptyString" }
			}
		}
	}
}
