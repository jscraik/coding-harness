{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://example.com/schemas/browser-evidence.json",
	"title": "Browser Evidence",
	"description": "Schema for browser-evidence/v1 manifests that point to rendered screenshots and console telemetry.",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"screenshots",
		"requiredViewportIds",
		"consoleEvents",
		"consolePolicy",
		"blankScreenshotPolicy"
	],
	"properties": {
		"schemaVersion": {
			"const": "browser-evidence/v1",
			"description": "Browser evidence manifest schema version."
		},
		"screenshots": {
			"type": "array",
			"minItems": 1,
			"description": "Rendered screenshot artifacts captured by viewport.",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["path", "viewportId", "width", "height"],
				"properties": {
					"path": {
						"type": "string",
						"minLength": 1,
						"description": "Repository-contained path to the screenshot artifact."
					},
					"viewportId": {
						"type": "string",
						"minLength": 1,
						"description": "Viewport identifier, such as desktop or mobile."
					},
					"width": {
						"type": "integer",
						"minimum": 1
					},
					"height": {
						"type": "integer",
						"minimum": 1
					},
					"description": {
						"type": "string"
					}
				}
			}
		},
		"requiredViewportIds": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			},
			"description": "Viewport IDs that must be represented by screenshots."
		},
		"consoleEvents": {
			"type": "array",
			"description": "Observed browser console events. Use an empty array when no events were observed.",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["level"],
				"properties": {
					"level": {
						"type": "string",
						"enum": ["error", "warning", "info", "log", "debug"]
					},
					"message": {
						"type": "string"
					},
					"text": {
						"type": "string"
					},
					"source": {
						"type": "string"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time"
					}
				}
			}
		},
		"consolePolicy": {
			"type": "object",
			"additionalProperties": false,
			"required": ["failOn"],
			"properties": {
				"failOn": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"enum": ["error", "warning", "info", "log", "debug"]
					},
					"description": "Console levels that fail browser-evidence validation."
				},
				"allowedMessagePatterns": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"blankScreenshotPolicy": {
			"type": "object",
			"additionalProperties": false,
			"required": ["minWidth", "minHeight", "minBytes", "minUniqueColors"],
			"properties": {
				"minWidth": {
					"type": "integer",
					"minimum": 1
				},
				"minHeight": {
					"type": "integer",
					"minimum": 1
				},
				"minBytes": {
					"type": "integer",
					"minimum": 1
				},
				"minUniqueColors": {
					"type": "integer",
					"minimum": 1
				}
			}
		}
	}
}
