{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/coding-harness/agent-native-ratchets.schema.json",
	"title": "Agent Native Ratchets",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "status", "ratchets"],
	"properties": {
		"schemaVersion": {
			"const": "agent-native-ratchets/v1"
		},
		"status": {
			"enum": ["pass", "needs_attention"]
		},
		"ratchets": {
			"type": "array",
			"minItems": 5,
			"maxItems": 5,
			"prefixItems": [
				{
					"allOf": [
						{
							"$ref": "#/$defs/ratchet"
						},
						{
							"type": "object",
							"required": ["id"],
							"properties": {
								"id": {
									"const": "orientation_packet"
								}
							}
						}
					]
				},
				{
					"allOf": [
						{
							"$ref": "#/$defs/ratchet"
						},
						{
							"type": "object",
							"required": ["id"],
							"properties": {
								"id": {
									"const": "session_distillation"
								}
							}
						}
					]
				},
				{
					"allOf": [
						{
							"$ref": "#/$defs/ratchet"
						},
						{
							"type": "object",
							"required": ["id"],
							"properties": {
								"id": {
									"const": "agent_rework_loop"
								}
							}
						}
					]
				},
				{
					"allOf": [
						{
							"$ref": "#/$defs/ratchet"
						},
						{
							"type": "object",
							"required": ["id"],
							"properties": {
								"id": {
									"const": "reviewer_decision_contract"
								}
							}
						}
					]
				},
				{
					"allOf": [
						{
							"$ref": "#/$defs/ratchet"
						},
						{
							"type": "object",
							"required": ["id"],
							"properties": {
								"id": {
									"const": "governance_decision_surface"
								}
							}
						}
					]
				}
			]
		}
	},
	"$defs": {
		"ratchet": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"status",
				"purpose",
				"command",
				"nativeAuthority",
				"sourceKind",
				"mayClaim",
				"mustNotClaim",
				"evidencePaths",
				"claimBoundary",
				"nextMove"
			],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1,
					"pattern": "\\S"
				},
				"status": {
					"enum": ["pass", "needs_attention"]
				},
				"purpose": {
					"type": "string",
					"minLength": 1,
					"pattern": "\\S"
				},
				"command": {
					"type": "string",
					"minLength": 1,
					"pattern": "\\S"
				},
				"nativeAuthority": {
					"enum": ["harness", "codex", "connector", "sidecar"]
				},
				"sourceKind": {
					"enum": [
						"repo_contract",
						"repo_worktree",
						"repo_artifact",
						"connector_snapshot",
						"sidecar_export",
						"normalized_external_snapshot"
					]
				},
				"mayClaim": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": {
						"type": "string",
						"minLength": 1,
						"pattern": "\\S"
					}
				},
				"mustNotClaim": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": {
						"type": "string",
						"minLength": 1,
						"pattern": "\\S"
					}
				},
				"evidencePaths": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1,
						"pattern": "\\S"
					}
				},
				"claimBoundary": {
					"type": "string",
					"minLength": 1,
					"pattern": "\\S"
				},
				"nextMove": {
					"type": "string",
					"minLength": 1,
					"pattern": "\\S"
				}
			}
		}
	}
}
