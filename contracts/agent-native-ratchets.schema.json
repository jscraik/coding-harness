{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/coding-harness/agent-native-ratchets.schema.json",
	"title": "Agent Native Ratchets",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "status", "ratchets"],
	"properties": {
		"schemaVersion": {
			"const": "agent-native-ratchets/v1"
		},
		"status": {
			"enum": ["pass", "needs_attention"]
		},
		"ratchets": {
			"type": "array",
			"minItems": 5,
			"items": {
				"$ref": "#/$defs/ratchet"
			}
		}
	},
	"$defs": {
		"ratchet": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"status",
				"purpose",
				"command",
				"evidencePaths",
				"claimBoundary",
				"nextMove"
			],
			"properties": {
				"$defs": {
					"nonEmptyText": {
						"type": "string",
						"minLength": 1,
						"pattern": "\\S"
					}
				},
				"id": {
					"$ref": "`#/`$defs/nonEmptyText"
				},
				"status": {
					"enum": ["pass", "needs_attention"]
				},
				"purpose": {
					"$ref": "`#/`$defs/nonEmptyText"
				},
				"command": {
					"$ref": "`#/`$defs/nonEmptyText"
				},
				"evidencePaths": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "`#/`$defs/nonEmptyText"
					}
				},
				"claimBoundary": {
					"$ref": "`#/`$defs/nonEmptyText"
				},
				"nextMove": {
					"$ref": "`#/`$defs/nonEmptyText"
				}
			}
		}
	}
}
