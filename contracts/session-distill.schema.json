{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/coding-harness/session-distill.schema.json",
	"title": "Session Distill",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"status",
		"branch",
		"headSha",
		"worktreeStatus",
		"changedFiles",
		"changedFileCount",
		"evidenceLanes",
		"nextCommands",
		"nonClaims",
		"claimBoundary"
	],
	"properties": {
		"schemaVersion": {
			"const": "session-distill/v1"
		},
		"status": {
			"enum": ["pass"]
		},
		"branch": {
			"type": "string",
			"minLength": 1
		},
		"headSha": {
			"type": "string",
			"pattern": "^[0-9a-f]{7,40}$"
		},
		"worktreeStatus": {
			"enum": ["clean", "dirty"]
		},
		"changedFiles": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"changedFileCount": {
			"type": "integer",
			"minimum": 0
		},
		"evidenceLanes": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/$defs/evidenceLane"
			}
		},
		"nextCommands": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"nonClaims": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"claimBoundary": {
			"type": "string",
			"minLength": 1
		}
	},
	"$defs": {
		"evidenceLane": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "status", "evidenceRefs"],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1
				},
				"status": {
					"type": "string",
					"minLength": 1
				},
				"evidenceRefs": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		}
	}
}
