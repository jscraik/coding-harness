{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://brainwav.dev/coding-harness/session-distill.schema.json",
	"title": "Session Distill",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schemaVersion",
		"status",
		"branch",
		"headSha",
		"worktreeStatus",
		"changedFiles",
		"changedFileCount",
		"nativeAuthority",
		"sourceKind",
		"mayClaim",
		"mustNotClaim",
		"evidenceLanes",
		"nextCommands",
		"nonClaims",
		"claimBoundary"
	],
	"properties": {
		"schemaVersion": {
			"const": "session-distill/v1"
		},
		"status": {
			"enum": ["pass"]
		},
		"branch": {
			"type": "string",
			"minLength": 1
		},
		"headSha": {
			"type": "string",
			"pattern": "^[a-f0-9]{7,40}$"
		},
		"worktreeStatus": {
			"enum": ["clean", "dirty"]
		},
		"changedFiles": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"changedFileCount": {
			"type": "integer",
			"minimum": 0
		},
		"nativeAuthority": {
			"const": "harness"
		},
		"sourceKind": {
			"const": "repo_worktree"
		},
		"mayClaim": {
			"type": "array",
			"minItems": 1,
			"uniqueItems": true,
			"items": {
				"$ref": "#/$defs/claimToken"
			}
		},
		"mustNotClaim": {
			"type": "array",
			"minItems": 1,
			"uniqueItems": true,
			"items": {
				"$ref": "#/$defs/claimToken"
			}
		},
		"evidenceLanes": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/$defs/evidenceLane"
			}
		},
		"nextCommands": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"nonClaims": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/$defs/claimToken"
			}
		},
		"claimBoundary": {
			"type": "string",
			"minLength": 1
		}
	},
	"$defs": {
		"claimToken": {
			"enum": [
				"ci_passed",
				"codex_context_current",
				"codex_session_truth",
				"connector_snapshot_current",
				"merge_ready",
				"repo_handoff_orientation",
				"review_threads_resolved",
				"sidecar_export_current",
				"tracker_closed",
				"validation_passed",
				"worktree_changed_files"
			]
		},
		"evidenceLane": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "status", "evidenceRefs"],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1
				},
				"status": {
					"type": "string",
					"minLength": 1
				},
				"evidenceRefs": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		}
	}
}
